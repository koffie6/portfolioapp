{
  "name": "portfolio-app",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:unit": "jest --testPathIgnorePatterns=__tests__/stress",
    "test:stress": "jest __tests__/stress",
    "test:performance": "jest __tests__/stress/DashboardPerformance.test.tsx"
  },
  "dependencies": {
    "expo": "^51.0.0",
    "react": "18.2.0",
    "react-native": "0.73.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.3",
    "@types/react": "^18.2.21",
    "@types/react-native": "^0.73.0",
    "jest": "^29.7.0",
    "jest-expo": "^51.0.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.tsx",
      "**/__tests__/**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ]
  }
}
